{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Telemetry": {
    "ServiceName": "HVO.AiCodeReview",
    "ServiceVersion": "1.0.0",
    "Environment": "Production",
    "Enabled": true,
    "DefaultSamplingRate": 1.0,
    "Queue": {
      "Capacity": 10000,
      "BatchSize": 100
    },
    "Features": {
      "EnableHttpInstrumentation": true,
      "EnableExceptionTracking": true,
      "EnableParameterCapture": false
    }
  },
  "AzureDevOps": {
    "Organization": "",
    "PersonalAccessToken": "",
    "ReviewTagName": "ai-code-review",
    "AddReviewerVote": true,
    "MinReviewIntervalMinutes": 5,
    "CommentAttributionTag": "AiCodeReview",
    "ResolveFixedThreadsOnReReview": true
  },
  "AzureOpenAI": {
    "Endpoint": "",
    "ApiKey": "",
    "DeploymentName": "",
    "MaxParallelReviews": 5
  },
  "AiProvider": {
    "MaxParallelReviews": 5,
    "MaxInputLinesPerFile": 5000,
    "Mode": "single",
    "ActiveProvider": "azure-openai",
    "ConsensusThreshold": 2,
    "DepthModels": {
      "Quick": "azure-openai-mini",
      "Standard": "azure-openai-mini",
      "Deep": "azure-openai-o4-mini"
    },
    "PassRouting": {
      "SecurityPass": "azure-openai-mini"
    },
    "Providers": {
      "azure-openai": {
        "Type": "azure-openai",
        "DisplayName": "Azure OpenAI (gpt-4o)",
        "Endpoint": "",
        "ApiKey": "",
        "Model": "gpt-4o",
        "Enabled": true
      },
      "azure-openai-mini": {
        "Type": "azure-openai",
        "DisplayName": "Azure OpenAI (gpt-4o-mini)",
        "Endpoint": "",
        "ApiKey": "",
        "Model": "gpt-4o-mini",
        "Enabled": true
      },
      "azure-openai-o3-mini": {
        "Type": "azure-openai",
        "DisplayName": "Azure OpenAI (o3-mini)",
        "Endpoint": "",
        "ApiKey": "",
        "Model": "o3-mini",
        "Enabled": true
      },
      "azure-openai-o4-mini": {
        "Type": "azure-openai",
        "DisplayName": "Azure OpenAI (o4-mini)",
        "Endpoint": "",
        "ApiKey": "",
        "Model": "o4-mini",
        "Enabled": true
      },
      "azure-openai-gpt5-mini": {
        "Type": "azure-openai",
        "DisplayName": "Azure OpenAI (gpt-5-mini)",
        "Endpoint": "",
        "ApiKey": "",
        "Model": "gpt-5-mini",
        "Enabled": true
      }
    }
  },
  "ReviewProfile": {
    "Temperature": 0.1,
    "MaxOutputTokensBatch": 16000,
    "MaxOutputTokensSingleFile": 4000,
    "MaxOutputTokensVerification": 2000,
    "MaxOutputTokensPrSummary": 4000
  },
  "Assistants": {
    "AutoThreshold": 5,
    "PollIntervalMs": 1000,
    "MaxPollAttempts": 120,
    "ApiVersion": "2024-05-01-preview",
    "MaxParallelUploads": 10
  },
  "SizeGuardrails": {
    "WarnFileCount": 30,
    "WarnChangedLines": 2000,
    "FocusModeMaxFiles": 20,
    "FocusModeEnabled": false
  },
  "TestCoverage": {
    "Enabled": true
  },
  "ReviewQueue": {
    "Enabled": false,
    "MaxConcurrentReviews": 3,
    "MaxQueueDepth": 50,
    "MaxConcurrentAiCalls": 8,
    "SessionTimeoutMinutes": 30
  }
}